<% layout("layouts/boilerplate") %>

<body>
  <div class="container mt-5">

    <div class="card p-4 shadow-sm mb-4">
      <h4 class="card-title mb-3"><%= listing.title %></h4>

      <ul class="list-group list-group-flush mb-3">
        <li class="list-group-item"><strong>Owned by:</strong> <i><%= listing.owner.username %></i></li>
        <li class="list-group-item"><strong>Description:</strong> <%= listing.description %></li>
        <li class="list-group-item"><strong>Price:</strong> ₹ <%= listing.price.toLocaleString("en-IN") %></li>
        <li class="list-group-item"><strong>Location:</strong> <%= listing.location %></li>
        <li class="list-group-item"><strong>Country:</strong> <%= listing.country %></li>
      </ul>

      <% if (listing.image && listing.image.url) { %>
        <div class="mb-3 text-center">
          <img src="<%= listing.image.url %>" alt="Listing Image" class="img-fluid rounded" style="max-height: 300px;" />
        </div>
      <% } %>

      <% if (currentUser && currentUser._id.toString() === listing.owner._id.toString()) { %>
        <div class="d-flex gap-3">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">Edit Listing</a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" onsubmit="return confirm('Are you sure you want to delete this listing?');">
            <button class="btn btn-danger">Delete Listing</button>
          </form>
        </div>
      <% } %>
    </div>

    <!-- Show Reviews -->
    <div class="card p-4 shadow-sm mb-5">
      <h5 class="mb-3">Reviews</h5>

      <% if (listing.reviews && listing.reviews.length > 0) { %>
        <% listing.reviews.forEach(review => { %>
          <div class="border-bottom pb-3 mb-3">
            <div class="mb-1">
              <strong>Created by:</strong> <i><%= review.author.username %></i>
            </div>
            <div class="text-warning mb-1">
              <% for (let i = 0; i < review.rating; i++) { %>★<% } %>
              <% for (let i = review.rating; i < 5; i++) { %><span class="text-secondary">★</span><% } %>
            </div>
            <p class="mb-1"><%= review.comment %></p>

            <div class="d-flex justify-content-between align-items-center">
              <% if (currentUser && currentUser._id.toString() === review.author._id.toString()) { %>
                <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                  <button class="btn btn-sm btn-dark mt-2">Delete</button>
                </form>
              <% } %>
              <small class="text-muted">
                <%= new Date(review.createdAt).toLocaleString("en-IN", {
                  day: "2-digit",
                  month: "2-digit",
                  year: "numeric",
                  hour: "2-digit",
                  minute: "2-digit",
                  hour12: true
                }) %>
              </small>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-muted">No reviews yet. Be the first to leave one!</p>
      <% } %>
    </div>

    <% if (currentUser) { %>
      <!-- Review Form -->
      <div class="card p-4 shadow-sm mb-5">
        <h5 class="mb-3">Leave a Review</h5>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
          <div class="mb-3">
            <label for="comment" class="form-label">Your Comment</label>
            <textarea class="form-control" id="comment" name="review[comment]" rows="3" required></textarea>
            <div class="invalid-feedback">Enter Comment</div>
          </div>

          <div class="mb-3">
            <label class="form-label d-block">Rating</label>
            <div class="star-rating">
              <input type="radio" name="review[rating]" value="5" id="star5"><label for="star5">★</label>
              <input type="radio" name="review[rating]" value="4" id="star4"><label for="star4">★</label>
              <input type="radio" name="review[rating]" value="3" id="star3"><label for="star3">★</label>
              <input type="radio" name="review[rating]" value="2" id="star2"><label for="star2">★</label>
              <input type="radio" name="review[rating]" value="1" id="star1"><label for="star1">★</label>
            </div>
          </div>

          <button type="submit" class="btn btn-success">Post Review</button>
        </form>
      </div>
    <% } %>

  </div> <!-- /container -->
</body>
