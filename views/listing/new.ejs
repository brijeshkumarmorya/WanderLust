<% layout("layouts/boilerplate") %>

<body>
  <div class="row">
    <div class="col-8 offset-2">
      <h3 class="mb-4 mt-4">Create a New Listing</h3>
      <form
        method="POST"
        action="/listings"
        class="needs-validation"
        novalidate
        enctype="multipart/form-data"
      >
        <div class="mb-3">
          <label for="title">Title</label>
          <input
            placeholder="Enter Title"
            type="text"
            name="listing[title]"
            id="title"
            class="form-control"
            required
          />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Enter a catchy Title</div>
        </div>

        <div class="mb-3">
          <label for="description">Description</label>
          <textarea
            placeholder="Enter Description"
            name="listing[description]"
            id="description"
            class="form-control"
            required
          ></textarea>
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Enter description</div>
        </div>

        <div class="mb-3">
          <label for="image">Upload Image</label>
          <input
            type="file"
            name="listing[image]"
            id="image"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Enter Image URL</div>
        </div>

        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="price">Price</label>
            <input
              placeholder="Enter Price/night"
              type="number"
              name="listing[price]"
              id="price"
              class="form-control"
              required
            />
            <div class="invalid-feedback">Enter Price/night</div>
          </div>

          <div class="mb-3 col-md-8">
            <label for="country">Country</label>
            <input
              placeholder="Enter Country"
              type="text"
              name="listing[country]"
              id="country"
              class="form-control"
              required
            />
            <div class="invalid-feedback">Enter Country name</div>
          </div>
        </div>

        <div class="mb-3">
          <label for="location">Location</label>
          <input
            placeholder="Enter Location"
            type="text"
            name="listing[location]"
            id="location"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Enter location</div>
        </div>

        <button type="submit" class="btn btn-dark mb-4">Add Listing</button>
      </form>
    </div>
  </div>

</body>
